{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Maestro",
  "version": "0.1.0",
  "identifier": "com.fushenguang.maestro",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Maestro",
        "width": 1024,
        "height": 768
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
