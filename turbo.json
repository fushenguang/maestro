{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": ["src/**", "index.html", "public/**", "package.json", "tsconfig.json", "vite.config.*"],
      "outputs": [
        "dist/**",
        "target/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "inputs": ["src/**", "*.test.*", "vitest.config.*"],
      "outputs": []
    }
  }
}
